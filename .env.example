# =============================================================
# EventHub Pro — Environment Variables Example
# Copy this file to .env.local and fill in your values
# =============================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="EventHub Pro"
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/eventhub_pro?schema=public"

# Auth.js / NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-nextauth-key-change-in-production

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# PayPal (https://developer.paypal.com/)
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox

# Redis (Upstash or Render Redis)
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_placeholder
EMAIL_FROM="EventHub Pro <noreply@yourdomain.com>"

# JWT (for ticket signing)
JWT_SECRET=your-jwt-secret-for-ticket-signing-change-in-production

# QR / Tickets
TICKET_SIGNING_SECRET=your-ticket-signing-secret

# File Upload (Cloudinary or S3)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# Admin
ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_SECRET=super-admin-bootstrap-secret
